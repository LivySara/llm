# 请前往 https://console.anthropic.com/ 申请并获取你的Anthropic API Key
# 将下方的 `your_api_key_here` 替换为你的真实API Key后，将本文件重命名为 `.env`
ANTHROPIC_API_KEY=your_api_key_here

# 中转站基础地址（可选，使用第三方中转站时配置，不配置则使用Anthropic官方默认地址）
ANTHROPIC_BASE_URL=https://your-base-url-here.com

# 自定义 User-Agent（可选，用于绕过中转站的 User-Agent 验证）
ANTHROPIC_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36